#!/bin/bash
# setup — opbstack installer
# ติดตั้งอัตโนมัติบน Claude Code, Paperclip, OpenClaw, Hermes, หรือ OpenCode legacy path
# Usage: ./setup [claude|paperclip|openclaw|hermes|opencode|auto]

set -e

OPBSTACK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SKILLS=(strategist brand build market content data serve admin money coach)
SKILL_NAMES=("thaistrategist" "thaibrand" "thaibuild" "thaimarket" "thaicontent" "thaidata" "thaiserve" "thaiadmin" "thaimoney" "thaicoach")

echo "☕ opbstack — Thai SME AI Agent Stack"
echo "=========================================="

# ─── Detect platform ───
PLATFORM="${1:-auto}"

if [ "$PLATFORM" = "auto" ]; then
  if [ -d "$HOME/.config/opencode" ] || command -v opencode &> /dev/null; then
    PLATFORM="opencode"
  elif [ -d "$HOME/.claude" ] || command -v claude &> /dev/null; then
    PLATFORM="claude"
  elif [ -d "$HOME/.paperclip" ] || command -v paperclipai &> /dev/null || command -v paperclip &> /dev/null; then
    PLATFORM="paperclip"
  elif [ -d "$HOME/.openclaw" ] || command -v openclaw &> /dev/null; then
    PLATFORM="openclaw"
  elif [ -d "$HOME/.hermes" ] || command -v hermes &> /dev/null; then
    PLATFORM="hermes"
  else
    echo ""
    echo "❓ ไม่พบ AI agent platform ที่ติดตั้งอยู่"
    echo ""
    echo "เลือก platform ที่ต้องการติดตั้ง:"
    echo "  1) opencode   — OpenCode + Model Ark (legacy path)"
    echo "  2) claude     — Claude Code (Anthropic)"
    echo "  3) paperclip  — Paperclip (Control Plane)"
    echo "  4) openclaw   — OpenClaw (self-hosted multi-provider assistant)"
    echo "  5) hermes     — Hermes Agent (persistent memory + self-learning)"
    echo ""
    read -p "เลือก (1-5): " choice
    case $choice in
      1) PLATFORM="opencode" ;;
      2) PLATFORM="claude" ;;
      3) PLATFORM="paperclip" ;;
      4) PLATFORM="openclaw" ;;
      5) PLATFORM="hermes" ;;
      *) echo "ยกเลิก" && exit 1 ;;
    esac
  fi
fi

echo ""
echo "🔧 ตรวจพบ platform: $PLATFORM"
echo ""

# ─── OpenCode (legacy path) ───
install_opencode() {
  OC_CONFIG="${OPENCODE_CONFIG_DIR:-$HOME/.config/opencode}"
  
  echo "📁 ติดตั้งที่: $OC_CONFIG"
  mkdir -p "$OC_CONFIG"
  
  # สร้าง skills symlink
  mkdir -p "$OC_CONFIG/skills"
  ln -sf "$OPBSTACK_DIR" "$OC_CONFIG/skills/opbstack"
  
  # สร้าง opencode.json ตัวอย่าง
  cat > "$OC_CONFIG/opbstack-example.json" << EOF
{
  "\$schema": "https://opencode.ai/config.json",
  "model": "byteplus-plan/ark-code-latest",
  "provider": {
    "byteplus-plan": {
      "name": "BytePlus",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://ark.ap-southeast.bytepluses.com/api/coding/v3",
        "apiKey": "YOUR_ARK_API_KEY_HERE"
      },
      "models": {
        "ark-code-latest": { "name": "ark-code-latest" },
        "dola-seed-2.0-pro": { "name": "dola-seed-2.0-pro" },
        "dola-seed-2.0-lite": { "name": "dola-seed-2.0-lite" },
        "bytedance-seed-code": { "name": "bytedance-seed-code" },
        "glm-4.7": { "name": "glm-4.7" },
        "kimi-k2.5": { "name": "kimi-k2.5" },
        "gpt-oss-120b": { "name": "gpt-oss-120b" }
      }
    }
  },
  "customCommands": {
    "strategist": { "description": "นักวางแผนธุรกิจ", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/strategist/SKILL.md and act as a Thai business strategist. Respond in Thai with English in parentheses." },
    "brand": { "description": "นักออกแบบแบรนด์", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/brand/SKILL.md and act as a Thai brand designer. Respond in Thai with English in parentheses." },
    "build": { "description": "นักสร้างระบบ", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/build/SKILL.md and act as a Thai web/system builder. Respond in Thai with English in parentheses." },
    "market": { "description": "นักการตลาด", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/market/SKILL.md and act as a Thai digital marketer. Respond in Thai with English in parentheses." },
    "content": { "description": "นักเขียนคอนเทนต์", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/content/SKILL.md and act as a Thai content creator. Respond in Thai with English in parentheses." },
    "data": { "description": "นักวิเคราะห์ข้อมูล", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/data/SKILL.md and act as a Thai data analyst. Respond in Thai with English in parentheses." },
    "serve": { "description": "นักบริการลูกค้า", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/serve/SKILL.md and act as a Thai customer success manager. Respond in Thai with English in parentheses." },
    "admin": { "description": "ธุรการ", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/admin/SKILL.md and act as a Thai business admin. Respond in Thai with English in parentheses." },
    "money": { "description": "นักการเงิน", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/money/SKILL.md and act as a Thai finance manager. Respond in Thai with English in parentheses." },
    "coach": { "description": "โค้ชธุรกิจ", "prompt": "Read $OPBSTACK_DIR/core/CLAUDE.md for rules. Then read $OPBSTACK_DIR/coach/SKILL.md and act as a Thai business coach. Respond in Thai with English in parentheses." }
  }
}
EOF
  
  echo ""
  echo "✅ ติดตั้ง opbstack บน OpenCode สำเร็จ!"
  echo ""
  echo "📋 ทดสอบด้วย:"
  echo "   opencode"
  echo "   /strategist วิเคราะห์ธุรกิจร้านกาแฟ"
  echo ""
  echo "⚡ แนะนำ: สมัคร BytePlus ModelArk Coding Plan (Lite $10 / Pro $50 ตาม list price ปัจจุบัน)"
  echo "   https://console.byteplus.com/ → ModelArk → Coding Plan"
  echo ""
  echo "📝 ขั้นตอนต่อไป:"
  echo "   1. แก้ไข $OC_CONFIG/opbstack-example.json ใส่ API Key"
  echo "   2. Copy ไปเป็น $OC_CONFIG/opencode.json"
  echo "   3. กรอก $OPBSTACK_DIR/business_context/TEMPLATE.md → BUSINESS.md"
  echo "   4. รัน opencode แล้วใช้ /strategist /brand /market ..."
}

# ─── Claude Code ───
install_claude() {
  CLAUDE_SKILLS="$HOME/.claude/skills"
  DEST="$CLAUDE_SKILLS/opbstack"
  
  echo "📁 ติดตั้งที่: $DEST"
  mkdir -p "$CLAUDE_SKILLS"
  
  # Copy skills (จริง ๆ ใช้ symlink หรือ copy ก็ได้)
  if [ "$OPBSTACK_DIR" != "$DEST" ]; then
    rm -rf "$DEST"
    cp -r "$OPBSTACK_DIR" "$DEST"
  fi
  
  # สร้าง CLAUDE.md ใน .claude/ ถ้ายังไม่มี
  CLAUDE_MD="$HOME/.claude/CLAUDE.md"
  
  if [ -f "$CLAUDE_MD" ]; then
    echo "📝 พบไฟล์ CLAUDE.md ที่มีอยู่แล้ว"
    echo "   เพิ่ม opbstack section..."
    
    # เช็คว่ามี opbstack section อยู่แล้วหรือไม่
    if grep -q "opbstack" "$CLAUDE_MD" 2>/dev/null; then
      echo "   ✓ opbstack ถูกติดตั้งแล้ว"
    else
      cat >> "$CLAUDE_MD" << 'EOF'

---

## opbstack — Thai SME AI Agent Stack

คุณมี 10 skills สำหรับธุรกิจ SME ไทย ใช้ได้ด้วยคำสั่ง:

**Phase 1 — วางรากฐาน:**
- `/strategist` — วางแผนธุรกิจ วิเคราะห์คู่แข่ง SWOT
- `/brand` — สร้างแบรนด์ โลโก้ สี โทนเสียง

**Phase 2 — สร้างช่องทาง:**
- `/build` — สร้างเว็บไซต์ LINE OA ระบบร้านค้า

**Phase 3 — ดึงลูกค้า:**
- `/market` — วางแผนการตลาด Facebook TikTok SEO
- `/content` — เขียนแคปชั่น คอนเทนต์ สคริปต์วิดีโอ

**Phase 4 — ดูแลและเติบโต:**
- `/data` — วิเคราะห์ยอดขาย Dashboard รายงาน
- `/serve` — ดูแลลูกค้า CRM Loyalty Program
- `/admin` — เอกสาร ใบเสนอราคา สัญญา
- `/money` — บัญชี ต้นทุน ภาษี Break-even
- `/coach` — Weekly review SOP เป้าหมาย

**กฎ:**
- ก่อนตอบทุกครั้ง ให้อ่าน `~/.claude/skills/opbstack/core/CLAUDE.md` เพื่อเข้าใจกติกาการทำงาน
- ถ้ามี `business_context/BUSINESS.md` ให้อ่านเพื่อเข้าใจบริบทธุรกิจ
- ถ้ามี `project_context/PROJECT.md` ให้อ่านเพื่อเข้าใจงานปัจจุบัน
- ตอบเป็นภาษาไทยเป็นหลัก เข้าใจง่าย ให้ตัวอย่างที่ copy ใช้ได้เลย
- ถามคำถามต่อเพื่อให้คำตอบลึกขึ้น
EOF
      echo "   ✓ เพิ่ม opbstack section เรียบร้อย"
    fi
  else
    echo "📝 สร้างไฟล์ CLAUDE.md..."
    mkdir -p "$HOME/.claude"
    cat > "$CLAUDE_MD" << 'EOF'
# CLAUDE.md — คำสั่งและบริบทสำหรับ Claude Code

## opbstack — Thai SME AI Agent Stack

คุณมี 10 skills สำหรับธุรกิจ SME ไทย ใช้ได้ด้วยคำสั่ง:

**Phase 1 — วางรากฐาน:**
- `/strategist` — วางแผนธุรกิจ วิเคราะห์คู่แข่ง SWOT
- `/brand` — สร้างแบรนด์ โลโก้ สี โทนเสียง

**Phase 2 — สร้างช่องทาง:**
- `/build` — สร้างเว็บไซต์ LINE OA ระบบร้านค้า

**Phase 3 — ดึงลูกค้า:**
- `/market` — วางแผนการตลาด Facebook TikTok SEO
- `/content` — เขียนแคปชั่น คอนเทนต์ สคริปต์วิดีโอ

**Phase 4 — ดูแลและเติบโต:**
- `/data` — วิเคราะห์ยอดขาย Dashboard รายงาน
- `/serve` — ดูแลลูกค้า CRM Loyalty Program
- `/admin` — เอกสาร ใบเสนอราคา สัญญา
- `/money` — บัญชี ต้นทุน ภาษี Break-even
- `/coach` — Weekly review SOP เป้าหมาย

**กฎ:**
- ก่อนตอบทุกครั้ง ให้อ่าน `~/.claude/skills/opbstack/core/CLAUDE.md` เพื่อเข้าใจกติกาการทำงาน
- ถ้ามี `business_context/BUSINESS.md` ให้อ่านเพื่อเข้าใจบริบทธุรกิจ
- ถ้ามี `project_context/PROJECT.md` ให้อ่านเพื่อเข้าใจงานปัจจุบัน
- ตอบเป็นภาษาไทยเป็นหลัก เข้าใจง่าย ให้ตัวอย่างที่ copy ใช้ได้เลย
- ถามคำถามต่อเพื่อให้คำตอบลึกขึ้น
EOF
    echo "   ✓ สร้าง CLAUDE.md เรียบร้อย"
  fi
  
  echo ""
  echo "✅ ติดตั้ง opbstack บน Claude Code สำเร็จ!"
  echo ""
  echo "📋 ทดสอบด้วยคำสั่ง:"
  echo "   /strategist วิเคราะห์ธุรกิจร้านกาแฟของฉัน"
  echo ""
  echo "📝 ขั้นตอนต่อไป:"
  echo "   1. กรอก business_context/TEMPLATE.md แล้วบันทึกเป็น BUSINESS.md"
  echo "   2. กรอก project_context/TEMPLATE.md แล้วบันทึกเป็น PROJECT.md"
  echo "   3. เริ่มใช้ /strategist /brand /market ... ได้เลย!"
}

# ─── Paperclip ───
install_paperclip() {
  PC_SKILLS="${PAPERCLIP_SKILLS_DIR:-$HOME/.paperclip/skills}"
  PC_CORE="${PAPERCLIP_DIR:-$HOME/.paperclip}"
  
  echo "📁 ติดตั้ง skills ที่: $PC_SKILLS"
  echo "📁 ติดตั้ง context ที่: $PC_CORE"
  
  mkdir -p "$PC_SKILLS"
  mkdir -p "$PC_CORE"
  
  # Copy skills
  for i in "${!SKILLS[@]}"; do
    src="$OPBSTACK_DIR/${SKILLS[$i]}"
    dst="$PC_SKILLS/${SKILL_NAMES[$i]}"
    rm -rf "$dst"
    cp -r "$src" "$dst"
    echo "   ✓ ${SKILL_NAMES[$i]} → ${SKILLS[$i]}"
  done
  
  # Copy context
  cp -r "$OPBSTACK_DIR/core" "$PC_CORE/" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/business_context" "$PC_CORE/" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/project_context" "$PC_CORE/" 2>/dev/null || true
  
  # สร้าง config file ตัวอย่าง
  cat > "$PC_CORE/opbstack-example.yaml" << EOF
# opbstack-example.yaml — ตัวอย่าง team template สำหรับ Paperclip
# ใช้เป็นแม่แบบสำหรับตั้งค่า company / agents ใน UI
# หรืออ้างอิง field names ตอนเรียก API/automation ภายหลัง

company: "ชื่อธุรกิจของคุณ"
version: "1.0"

agents:
  - id: strategist
    name: "Strategist"
    skill: thaistrategist
    adapter: claude_local
    budget_monthly: 10

  - id: brand
    name: "Brand"
    skill: thaibrand
    adapter: claude_local
    budget_monthly: 10

  - id: build
    name: "Build"
    skill: thaibuild
    adapter: claude_local
    budget_monthly: 15

  - id: market
    name: "Market"
    skill: thaimarket
    adapter: claude_local
    budget_monthly: 15

  - id: content
    name: "Content"
    skill: thaicontent
    adapter: claude_local
    budget_monthly: 12

  - id: data
    name: "Data"
    skill: thaidata
    adapter: claude_local
    budget_monthly: 8

  - id: serve
    name: "Serve"
    skill: thaiserve
    adapter: claude_local
    budget_monthly: 8

  - id: admin
    name: "Admin"
    skill: thaiadmin
    adapter: claude_local
    budget_monthly: 5

  - id: money
    name: "Money"
    skill: thaimoney
    adapter: claude_local
    budget_monthly: 5

  - id: coach
    name: "Coach"
    skill: thaicoach
    adapter: claude_local
    budget_monthly: 5
EOF
  
  echo ""
  echo "✅ ติดตั้ง opbstack บน Paperclip สำเร็จ!"
  echo ""
  echo "📋 ทดสอบด้วย:"
  echo "   ls $PC_SKILLS"
  echo ""
  echo "📝 ขั้นตอนต่อไป:"
  echo "   1. แก้ไข $PC_CORE/opbstack-example.yaml ตามธุรกิจของคุณ"
  echo "   2. กรอก $PC_CORE/business_context/TEMPLATE.md → BUSINESS.md"
  echo "   3. รัน: npx paperclipai onboard --yes หรือ pnpm paperclipai run"
  echo "   4. เปิด UI ที่ http://localhost:3100 แล้วสร้าง company / CEO / agents"
  echo "   5. ใช้ template นี้เป็นแม่แบบสำหรับ adapter, budget, และ role mapping"
}

# ─── OpenClaw ───
install_openclaw() {
  OC_SKILLS="${OPENCLAW_SKILLS_DIR:-$HOME/.openclaw/skills}"
  
  echo "📁 ติดตั้งที่: $OC_SKILLS"
  mkdir -p "$OC_SKILLS"
  
  # Copy skills (OpenClaw ใช้ชื่อ skill ตรง ๆ)
  for i in "${!SKILLS[@]}"; do
    src="$OPBSTACK_DIR/${SKILLS[$i]}"
    dst="$OC_SKILLS/opbstack-${SKILLS[$i]}"
    rm -rf "$dst"
    cp -r "$src" "$dst"
    echo "   ✓ opbstack-${SKILLS[$i]}"
  done
  
  # Copy context
  mkdir -p "$HOME/.openclaw"
  cp "$OPBSTACK_DIR/core/CLAUDE.md" "$HOME/.openclaw/CLAUDE.md" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/business_context" "$HOME/.openclaw/" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/project_context" "$HOME/.openclaw/" 2>/dev/null || true
  
  echo ""
  echo "✅ ติดตั้ง opbstack บน OpenClaw สำเร็จ!"
  echo ""
  echo "📋 ทดสอบด้วย:"
  echo "   openclaw skill list"
  echo ""
  echo "📝 ขั้นตอนต่อไป:"
  echo "   1. กรอก ~/.openclaw/business_context/TEMPLATE.md → BUSINESS.md"
  echo "   2. ใช้ skill: 'opbstack-strategist วิเคราะห์ธุรกิจของฉัน'"
}

# ─── Hermes ───
install_hermes() {
  HERMES_SKILLS="${HERMES_SKILLS_DIR:-$HOME/.hermes/skills}"
  
  echo "📁 ติดตั้งที่: $HERMES_SKILLS"
  mkdir -p "$HERMES_SKILLS"
  
  # Hermes ใช้ SKILL.md ตรง ๆ
  for i in "${!SKILLS[@]}"; do
    src="$OPBSTACK_DIR/${SKILLS[$i]}"
    dst="$HERMES_SKILLS/opbstack-${SKILLS[$i]}"
    rm -rf "$dst"
    cp -r "$src" "$dst"
    echo "   ✓ opbstack-${SKILLS[$i]}"
  done
  
  # Copy context
  mkdir -p "$HOME/.hermes"
  cp "$OPBSTACK_DIR/core/CLAUDE.md" "$HOME/.hermes/CLAUDE.md" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/business_context" "$HOME/.hermes/" 2>/dev/null || true
  cp -r "$OPBSTACK_DIR/project_context" "$HOME/.hermes/" 2>/dev/null || true
  
  echo ""
  echo "✅ ติดตั้ง opbstack บน Hermes Agent สำเร็จ!"
  echo ""
  echo "📋 Hermes จะเรียนรู้ skills เหล่านี้และปรับปรุงเองอัตโนมัติ"
  echo ""
  echo "📝 ขั้นตอนต่อไป:"
  echo "   1. กรอก ~/.hermes/business_context/TEMPLATE.md → BUSINESS.md"
  echo "   2. รอ Hermes เรียนรู้ skills (อัตโนมัติ)"
  echo "   3. เริ่มใช้: 'วิเคราะห์ธุรกิจ' (Hermes จะเลือก skill ที่เหมาะสมเอง)"
}

# ═══════════════════════════════════════════════════════════════════
# MAIN
# ═══════════════════════════════════════════════════════════════════

echo ""
case "$PLATFORM" in
  opencode)
    install_opencode
    ;;
  claude)
    install_claude
    ;;
  paperclip)
    install_paperclip
    ;;
  openclaw)
    install_openclaw
    ;;
  hermes)
    install_hermes
    ;;
  *)
    echo "❌ ไม่รู้จัก platform: $PLATFORM"
    echo "ใช้: ./setup [opencode|claude|paperclip|openclaw|hermes|auto]"
    exit 1
    ;;
esac

echo ""
echo "☕ opbstack พร้อมใช้งาน!"
echo "   10 skills | 4 platforms | 1 คำสั่ง"
echo ""
